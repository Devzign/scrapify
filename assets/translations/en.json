    "q1": {
      "question": "How to book a pickup?",
      "answer": "Go to the home screen, tap 'Schedule', and select your items from the list. Choose a date and time that works for you."
    },
    "q2": {
      "question": "What are the scrap rates?",
      "answer": "Rates are updated daily based on market prices. You can check the current rates in the 'Price List' tab at the bottom."
    },
    "q3": {
      "question": "How do I get paid?",
      "answer": "Payment is made instantly via UPI (GPay, PhonePe, Paytm) or cash at the time of pickup once the items are weighed."
    },
    "q4": {
      "question": "Can I reschedule my pickup?",
      "answer": "Yes, go to 'My Pickups', select the active booking, and tap 'Reschedule'. You can change the time up to 1 hour before arrival."
    },
    "q5": {
      "question": "What items do you NOT collect?",
      "answer": "We currently do not accept glass, wood, or hazardous medical waste. Please check the 'Restricted Items' list."
    },
    "chat_support": "Still need help? Chat with us"
  },
