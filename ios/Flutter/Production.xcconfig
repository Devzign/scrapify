// Target-level xcconfig for Production flavor.
// The Pods xcconfig (Pods-Runner.release-production.xcconfig) must be set at the
// PROJECT level (blue Runner row → "None" → pick Pods-Runner.release-production.xcconfig).
#include "Release.xcconfig"

// ── Production flavor overrides ───────────────────────────────────────────────
FLUTTER_TARGET=lib/main_production.dart
APP_DISPLAY_NAME=Scrapify
PRODUCT_BUNDLE_IDENTIFIER=com.abhyuthanam.scrapify
